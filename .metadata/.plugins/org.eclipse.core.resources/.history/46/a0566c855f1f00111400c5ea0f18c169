			j++;
		}

//Do- while loop
		int k = 1;
		do {
			if (k % 10 == 0) {
				k++;
				continue;
			} else if (k > 100) {
				break;
			} else {
				System.out.println(k);
			}
			k++;
		} while (k <= num);

	}
